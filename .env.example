# CFO Command Center - Environment Variables
# Copy this file to .env.local and fill in values

# =============================================================================
# Supabase Configuration
# =============================================================================
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# Anthropic Claude API
# =============================================================================
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# =============================================================================
# Google APIs (Gmail + Drive)
# =============================================================================
# Get from: Google Cloud Console → APIs & Services → Credentials
# 1. Create OAuth 2.0 Client ID (Desktop app type)
# 2. Enable Gmail API and Google Drive API
# 3. Use OAuth Playground to get refresh token:
#    https://developers.google.com/oauthplayground
GOOGLE_CLIENT_ID=123456789-abcdefg.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REFRESH_TOKEN=1//0abc...

# Google Drive folder ID for CPA exports
# Create folder in Drive, get ID from URL: drive.google.com/drive/folders/{ID}
GOOGLE_DRIVE_FOLDER_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ

# =============================================================================
# Notifications
# =============================================================================
# Email address for sending notifications
NOTIFICATION_EMAIL=dylan@mondayandpartners.com

# =============================================================================
# Cron Job Security
# =============================================================================
# Generate a random string: openssl rand -base64 32
# This protects cron endpoints from unauthorized access
CRON_SECRET=your-random-secret-here

# =============================================================================
# Application URL
# =============================================================================
# Used in email links and OAuth callbacks
NEXT_PUBLIC_APP_URL=https://cfo.mondayandpartners.com

# For local development:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
